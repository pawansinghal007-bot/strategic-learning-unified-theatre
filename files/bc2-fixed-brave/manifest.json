{
  "manifest_version": 3,
  "name": "Browser Capture",
  "version": "2.0.0",
  "description": "Captures browsing and AI chat activity to a local SQLite DB with Ollama integration.",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "nativeMessaging",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Browser Capture",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  }
}
