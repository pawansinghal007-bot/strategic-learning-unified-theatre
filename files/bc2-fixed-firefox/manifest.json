{
  "manifest_version": 2,
  "name": "Browser Capture",
  "version": "2.0.0",
  "description": "Captures browsing and AI chat activity to a local SQLite DB with Ollama integration.",

  "browser_specific_settings": {
    "gecko": {
      "id": "browser-capture@garuda.local",
      "strict_min_version": "115.0"
    }
  },

  "permissions": [
    "<all_urls>",
    "tabs",
    "storage",
    "nativeMessaging"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_title": "Browser Capture",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  }
}
