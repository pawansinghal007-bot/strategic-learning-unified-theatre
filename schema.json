{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VS Code Rotator Account",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "email",
    "agentType",
    "authBlob",
    "profileName",
    "cooldownUntil",
    "lastUsed",
    "status"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "email": { "type": "string", "format": "email" },
    "agentType": {
      "type": "string",
      "enum": ["vscode", "codex", "trae", "other"]
    },
    "authBlob": { "type": ["string", "null"], "minLength": 1 },
    "profileName": { "type": ["string", "null"], "minLength": 1 },
    "cooldownUntil": { "type": ["string", "null"], "format": "date-time" },
    "lastUsed": { "type": ["string", "null"], "format": "date-time" },
    "status": { "type": "string", "enum": ["active", "cooldown", "retired"] }
  }
}
