{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/shared/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
  "files": [
    "src/shared/contracts/provider.ts",
    "src/shared/schemas/provider.schema.ts",
    "src/shared/errors/base.ts",
    "src/shared/errors/provider.error.ts",
    "src/shared/errors/routing.error.ts",
    "src/shared/errors/memory.error.ts",
    "src/shared/errors/validation.error.ts",
    "src/shared/errors/index.ts"
  ]
}
