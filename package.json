{
  "name": "vscode-rotator",
  "version": "0.1.0",
  "description": "Hands-free VS Code account rotation with OS secret storage, tray UI, daemon service, and profile management.",
  "type": "module",
  "main": "./src/cli.js",
  "electron": "./electron-tray/main.js",
  "bin": {
    "vscode-rotator": "./src/cli.js"
  },
  "scripts": {
    "start": "node ./src/cli.js",
    "test": "cross-env VSCODE_ROTATOR_MOCK_LLM=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "test:serial": "node run-tests.cjs",
    "test:robot:functional": "node ./src/test-runner.js suite --suite functional",
    "test:robot:nonfunctional": "node ./src/test-runner.js suite --suite non_functional",
    "test:robot:regression": "node ./src/test-runner.js suite --suite regression",
    "test:robot:all": "node ./src/test-runner.js suite --suite all",
    "test:tdd": "node ./src/test-runner.js tdd-check",
    "tray": "electron ./electron-tray/main.js",
    "install-service": "node ./scripts/install.js",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "electron:dev": "npm run ui:build && cross-env NODE_ENV=development electron ./electron-ui/main.cjs",
    "electron:build": "npm run ui:build && electron-builder"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.vscode.rotator",
    "productName": "VSCode Rotator",
    "extraMetadata": {
      "main": "electron-ui/main.cjs"
    },
    "files": [
      "electron-ui/dist/**/*",
      "electron-ui/main.cjs",
      "electron-ui/preload.cjs",
      "electron-ui/ipc/**/*",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "icon": "build/icon.ico"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "electron-store": "^10.0.0",
    "fflate": "^0.8.2",
    "gray-matter": "^4.0.3",
    "keytar": "^7.9.0",
    "marked": "^12.0.0",
    "nanoid": "^5.0.7",
    "ora": "^8.0.1",
    "playwright": "^1.48.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "mammoth": "^1.8.0",
    "node-llama-cpp": "^3.14.0",
    "onnxruntime-node": "^1.20.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.3",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "author": "Pawan Singhal"
}
