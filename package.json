{
  "name": "strategic-learning-unified-theatre",
  "version": "0.1.0",
  "description": "Strategic Learning Unified Theatre local project with screen capture, LLM ingestion, and adapter training.",
  "type": "module",
  "main": "./src/cli.js",
  "electron": "./electron-tray/main.js",
  "bin": {
    "strategic-learning-unified-theatre": "./src/cli.js"
  },
  "scripts": {
    "start": "node ./src/cli.js",
    "test": "cross-env VSCODE_ROTATOR_MOCK_LLM=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "coverage": "cross-env VSCODE_ROTATOR_MOCK_LLM=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run -c vitest.test-ci.config.ts --coverage",
    "coverage:guarded": "npm run coverage && cross-env VITEST_INCLUDE_GUARD_TESTS=1 npx vitest run tests/sprint91-sonar-fix-guard.test.js tests/sprint92-thread-and-coverage-guard.test.js",
    "coverage:report": "vitest run --coverage --reporter=html",
    "test:ci": "cross-env VSCODE_ROTATOR_MOCK_LLM=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run -c vitest.test-ci.config.ts --coverage --reporter=verbose",
    "test:integration": "cross-env VSCODE_ROTATOR_MOCK_LLM=0 NODE_OPTIONS=--max-old-space-size=8192 vitest -c vitest.integration.config.js run",
    "test:serial": "node run-tests.cjs",
    "test:chaos": "node ./scripts/chaos/run-chaos.js",
    "test:chaos:kill-daemon": "node ./scripts/chaos/run-chaos.js --scenario kill-daemon",
    "test:chaos:corrupt-config": "node ./scripts/chaos/run-chaos.js --scenario corrupt-config",
    "test:chaos:burst-load": "node ./scripts/chaos/run-chaos.js --scenario burst-load",
    "test:chaos:network-drop": "node ./scripts/chaos/run-chaos.js --scenario network-drop",
    "test:chaos:disk-full": "node ./scripts/chaos/run-chaos.js --scenario disk-full",
    "test:chaos:slow-llm": "node ./scripts/chaos/run-chaos.js --scenario slow-llm",
    "test:chaos:crash-renderer": "node ./scripts/chaos/run-chaos.js --scenario crash-renderer",
    "test:chaos:memory-leak": "node ./scripts/chaos/run-chaos.js --scenario memory-leak",
    "test:chaos:zombie-process": "node ./scripts/chaos/run-chaos.js --scenario zombie-process",
    "test:chaos:double-start": "node ./scripts/chaos/run-chaos.js --scenario double-start",
    "test:robot": "robot --outputdir robot-results robot/",
    "test:robot:functional": "robot --outputdir robot-results --suite functional robot/",
    "test:robot:regression": "robot --outputdir robot-results --suite regression robot/",
    "test:robot:nonfunc": "robot --outputdir robot-results --suite non-functional robot/",
    "test:human": "npm run ui:build && npm run build:electron-main && npx playwright test -c playwright.human.config.cjs",
    "test:human:headed": "npm run ui:build && npm run build:electron-main && npx playwright test -c playwright.human.config.cjs --headed",
    "test:human:debug": "npm run ui:build && npm run build:electron-main && npx playwright test -c playwright.human.config.cjs --debug",
    "test:human:smoke": "npm run ui:build && npm run build:electron-main && npx playwright test tests/human/launch.spec.js -c playwright.human.config.cjs",
    "test:ui": "npm run ui:build && npm run build:electron-main && npx playwright test -c playwright.ui.config.cjs",
    "test:ui:headed": "npm run ui:build && npm run build:electron-main && npx playwright test -c playwright.ui.config.cjs --headed",
    "test:ui:theme": "npm run ui:build && npm run build:electron-main && npx playwright test tests/ui/theme-readability.spec.js -c playwright.ui.config.cjs",
    "test:ui:layers": "npm run ui:build && npm run build:electron-main && npx playwright test tests/ui/browser-pane-overlap.spec.js tests/ui/browser-pane-hide.spec.js -c playwright.ui.config.cjs",
    "test:tdd": "node ./src/test-runner.js tdd-check",
    "tray": "electron ./electron-tray/main.js",
    "install-service": "node ./scripts/install.js",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "electron:dev": "npm run ui:build && npm run build:electron-main && cross-env NODE_ENV=development electron ./electron-ui/main.bundled.cjs",
    "electron:build": "npm run ui:build && electron-builder",
    "dist:win": "electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:mac": "electron-builder --mac zip",
    "dist:all": "electron-builder -mwl",
    "dist": "npm run dist:all",
    "validate:governance": "node scripts/validate-governance-config.mjs",
    "sonar:validate-waivers": "node scripts/validate-waivers.mjs",
    "sonar:reconcile": "node scripts/reconcile-hotspot-register.mjs",
    "sonar:check": "node scripts/check-sonar-readiness.mjs",
    "sonar:preflight": "node scripts/check-sonar-preflight.mjs",
    "sonar:scan": "npx sonar-scanner",
    "sonar:qualitygate": "node scripts/check-sonar-quality-gate.mjs",
    "sonar:issues": "node scripts/export-sonar-issues.mjs",
    "test:sonar": "npm run sonar:preflight && npm run sonar:scan && npm run sonar:qualitygate && npm run sonar:issues",
    "build:electron-main": "node scripts/build-electron-main.mjs",
    "harness": "tsx src/agents/cli.ts",
    "mcp:server": "tsx src/mcp/server.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "com.strategiclearning.unifiedtheatre",
    "productName": "UnifiedTheatre",
    "extraMetadata": {
      "main": "electron-ui/main.cjs"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-ui/dist/**/*",
      "electron-ui/main.cjs",
      "electron-ui/preload.cjs",
      "electron-ui/ipc/**/*",
      "src/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.example.com/unifiedtheatre"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "icon": "resources/icons"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pg": "8.11.10",
    "@xenova/transformers": "^2.17.2",
    "@zilliz/milvus2-sdk-node": "^3.0.3",
    "ajv": "^8.12.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.0.0",
    "fflate": "^0.8.3",
    "gray-matter": "^4.0.3",
    "keytar": "^7.9.0",
    "llama": "^2.2.0",
    "marked": "^18.0.4",
    "nanoid": "^5.1.11",
    "ora": "^9.4.0",
    "pg": "8.13.3",
    "playwright": "^1.60.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "mammoth": "^1.12.0",
    "onnxruntime-node": "^1.26.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.5",
    "tsx": "^4.22.5",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "protobufjs": ">=7.6.3",
    "tar": ">=7.5.16"
  },
  "author": {
    "name": "Pawan Singhal",
    "email": "pawansinghal@garudatechnology.co.in"
  }
}
